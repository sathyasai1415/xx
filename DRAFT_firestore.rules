rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    function isValidUser(data) {
      return data.keys().hasAny(['email', 'created_at']) &&
             data.email is string &&
             data.created_at is string;
    }

    function isValidStore(data) {
      return data.keys().hasAny(['unique_store_id', 'store_name', 'created_at']) &&
             data.unique_store_id is string &&
             data.store_name is string;
    }

    function isValidMenuPrice(data) {
      return data.keys().hasAny(['store_id', 'item_name', 'base_price']) &&
             data.store_id is string &&
             data.item_name is string &&
             data.base_price is number;
    }

    function isValidDeal(data) {
      return data.keys().hasAny(['store_id', 'title', 'discounted_price']) &&
             data.store_id is string &&
             data.title is string &&
             data.discounted_price is number;
    }

    function isValidPizzaConfig(data) {
      return data.keys().hasAny(['user_id', 'pizza_name', 'size']) &&
             data.user_id is string &&
             data.pizza_name is string &&
             data.size is string;
    }
    
    // Store Admin Check: User is logged in and their UID matches a store's admin email mapping or storeId.
    // For simplicity without custom claims, check if the store document has `is_active == true`?
    // Actually, in our frontend, Store Admin logs in using storeId@stores.mislice.com which translates to a Firebase UID.
    // We treat the store document's `owner_auth_id` as the auth uid, OR we assume the store document ID itself is the UID!
    // If storeId is the Firebase Auth UID, then it's highly secure.

    match /users/{userId} {
      allow read, update, delete: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
    }

    match /stores/{storeId} {
      // Public reads on stores to see who is nearby
      allow read: if true;
      allow update: if isSignedIn() && request.auth.uid == storeId && isValidStore(incoming());
      allow create: if isSignedIn() && request.auth.uid == storeId && isValidStore(incoming());
    }

    match /stores/{storeId}/menu_prices/{priceId} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == storeId && isValidMenuPrice(incoming());
    }

    match /deals/{dealId} {
      allow read: if true;
      // Deals can only be modified by the store owner (determined by store_id == uid)
      allow write: if isSignedIn() && incoming().store_id == request.auth.uid && isValidDeal(incoming());
      allow update, delete: if isSignedIn() && existing().store_id == request.auth.uid;
    }

    match /pizza_configurations/{configId} {
      allow read, update, delete: if isSignedIn() && existing().user_id == request.auth.uid;
      allow create: if isSignedIn() && incoming().user_id == request.auth.uid && isValidPizzaConfig(incoming());
    }
  }
}
