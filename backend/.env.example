# Copy to .env and fill in. Never commit real secrets.
SPRING_PROFILES_ACTIVE=dev

# Database
DB_URL=jdbc:postgresql://localhost:5432/mislice
DB_USERNAME=mislice
DB_PASSWORD=change-me

# JWT — must be a Base64-encoded 256-bit (32-byte) secret
# Generate: openssl rand -base64 32
JWT_SECRET=change-me-base64-32-bytes
JWT_ACCESS_TTL=15
JWT_REFRESH_TTL=14

# CORS (comma-separated). The Vite dev server runs on 5173.
CORS_ORIGINS=http://localhost:5173

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Mail (dev: a local MailHog/Mailpit on 1025)
MAIL_HOST=localhost
MAIL_PORT=1025

# Payments (Phase 4)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
