rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isStoreAdmin(storeId) { return isSignedIn() && request.auth.uid == storeId; }
    function isPlatformAdmin() { return isSignedIn() && request.auth.token.email == 'sathyasai1415@gmail.com'; }

    match /users/{userId} {
      allow read, update, delete: if isOwner(userId) || isPlatformAdmin();
      allow create: if isOwner(userId) || isPlatformAdmin();
    }

    match /stores/{storeId} {
      allow read: if true;
      allow write: if isStoreAdmin(storeId) || isPlatformAdmin();
    }

    match /menus/{menuId} {
      allow read: if true;
      allow write: if isStoreAdmin(request.resource.data.storeId) || (resource != null && isStoreAdmin(resource.data.storeId)) || isPlatformAdmin();
    }
    
    match /stores/{storeId}/menu_prices/{priceId} {
      allow read: if true;
      allow write: if isStoreAdmin(storeId) || isPlatformAdmin();
    }
    
    match /stores/{storeId}/settings/{settingId} {
      allow read: if true;
      allow write: if isStoreAdmin(storeId) || isPlatformAdmin();
    }

    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isPlatformAdmin();
    }

    match /deals/{dealId} {
      allow read: if true;
      allow write: if isStoreAdmin(request.resource.data.store_id) || (resource != null && isStoreAdmin(resource.data.store_id)) || isPlatformAdmin();
    }

    match /orders/{orderId} {
      allow create: if isOwner(request.resource.data.userId) || isPlatformAdmin();
      allow read, update: if isOwner(resource.data.userId) || isStoreAdmin(resource.data.storeId) || isPlatformAdmin();
      allow delete: if isPlatformAdmin();
    }

    match /order_items/{itemId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn(); // We could constrain this by join but simple for MVP
    }

    match /pizza_configurations/{configId} {
      allow read, update, delete: if 'user_id' in resource.data && isOwner(resource.data.user_id);
      allow create: if isOwner(request.resource.data.user_id);
    }

    match /cart_items/{itemId} {
      allow read, update, delete: if 'user_id' in resource.data && isOwner(resource.data.user_id);
      allow create: if isOwner(request.resource.data.user_id);
    }
  }
}

