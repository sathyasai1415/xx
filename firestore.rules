rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isSelf(uid) { return isSignedIn() && request.auth.uid == uid; }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Store ownership is tracked via ownerUid field on the store document.
    function isStoreOwner(storeId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/stores/$(storeId)).data.ownerUid == request.auth.uid;
    }

    // ── User profiles ─────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSelf(userId) || isAdmin();
      allow create: if isSelf(userId);
      allow update: if isSelf(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Stores (public catalog) ───────────────────────────────────────────
    match /stores/{storeId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isStoreOwner(storeId) || isAdmin();
      allow delete: if isAdmin();

      match /menu/{itemId} {
        allow read: if true;
        allow write: if isStoreOwner(storeId) || isAdmin();
      }
      match /settings/{settingId} {
        allow read: if true;
        allow write: if isStoreOwner(storeId) || isAdmin();
      }
    }

    // ── Deals (public read; store owner or admin writes) ───────────────────
    match /deals/{dealId} {
      allow read: if true;
      allow create: if isSignedIn() &&
        isStoreOwner(request.resource.data.store_id);
      allow update, delete: if resource != null &&
        (isStoreOwner(resource.data.store_id) || isAdmin());
    }

    // ── Coupons (public read; admin-only writes) ───────────────────────────
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Orders ────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      // Customer creates their own order
      allow create: if isSignedIn() &&
        (request.resource.data.userId == request.auth.uid ||
         request.resource.data.customerId == request.auth.uid);

      // Customer or store owner or admin can read
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.customerId == request.auth.uid ||
        isStoreOwner(resource.data.storeId) ||
        isAdmin()
      );

      // Customer can cancel; store owner can advance status; admin can do anything
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.customerId == request.auth.uid ||
        isStoreOwner(resource.data.storeId) ||
        isAdmin()
      );

      allow delete: if false;
    }

    // ── Reviews ───────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && isSelf(request.resource.data.userId);
      allow update, delete: if isSignedIn() && isSelf(resource.data.userId);
    }

    // ── Audit log (admin reads; Cloud Functions write) ────────────────────
    match /audit/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
