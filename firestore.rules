rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isSelf(uid) { return isSignedIn() && request.auth.uid == uid; }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Store ownership is tracked via ownerUid field on the store document.
    function isStoreOwner(storeId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/stores/$(storeId)) &&
        get(/databases/$(database)/documents/stores/$(storeId)).data.ownerUid == request.auth.uid;
    }

    // ── User profiles ─────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSelf(userId) || isAdmin();
      allow create: if isSelf(userId);
      allow update: if isSelf(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Roles ─────────────────────────────────────────────────────────────
    match /roles/{roleId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Stores (public catalog) ───────────────────────────────────────────
    match /stores/{storeId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isStoreOwner(storeId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Menu Items (top-level collection) ─────────────────────────────────
    match /menu_items/{itemId} {
      allow read: if true;
      allow create: if isSignedIn() && (isStoreOwner(request.resource.data.storeId) || isAdmin());
      allow update, delete: if isSignedIn() && (
        (resource != null && isStoreOwner(resource.data.storeId)) || isAdmin()
      );
    }

    // ── Deals (public read; store owner or admin writes) ───────────────────
    match /deals/{dealId} {
      allow read: if true;
      allow create: if isSignedIn() && (isStoreOwner(request.resource.data.store_id) || isAdmin());
      allow update, delete: if resource != null && (isStoreOwner(resource.data.store_id) || isAdmin());
    }

    // ── Coupons (public read; admin-only writes) ───────────────────────────
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Orders ────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow create: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid ||
        request.resource.data.customerId == request.auth.uid
      );
      allow read, update: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.customerId == request.auth.uid ||
        isStoreOwner(resource.data.storeId) ||
        isAdmin()
      );
      allow delete: if false;
    }

    // ── Reviews ───────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && isSelf(request.resource.data.userId);
      allow update, delete: if isSignedIn() && isSelf(resource.data.userId);
    }

    // ── Favorites (decoupled) ─────────────────────────────────────────────
    match /favorites/{favId} {
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // ── Categories ────────────────────────────────────────────────────────
    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Notifications ─────────────────────────────────────────────────────
    match /notifications/{notId} {
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // ── Audit Logs ────────────────────────────────────────────────────────
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Admin SDK / server-only writes
    }

    // ── Price History ─────────────────────────────────────────────────────
    match /price_history/{histId} {
      allow read: if true;
      allow write: if isSignedIn() && (isStoreOwner(request.resource.data.storeId) || isAdmin());
    }

    // ── Store Locations ───────────────────────────────────────────────────
    match /store_locations/{locId} {
      allow read: if true;
      allow write: if isSignedIn() && (isStoreOwner(locId) || isAdmin());
    }

    // ── User Preferences ──────────────────────────────────────────────────
    match /user_preferences/{prefId} {
      allow read, write: if isSelf(prefId);
    }

    // ── Reports ───────────────────────────────────────────────────────────
    match /reports/{repId} {
      allow read, update, delete: if isAdmin();
      allow create: if isSignedIn();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
